{
  "manifest_version": 3,
  "name": "Chrome AI Pet",
  "version": "1.0.0",
  "description": "A cute AI pet for your Chrome browser with dynamic expressions and interactive features",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Chrome AI Pet"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["assets/main.css"],
      "js": ["assets/content.js"]
    }
  ]
}
