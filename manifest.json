{
  "manifest_version": 3,
  "name": "Chrome AI Pet",
  "version": "1.0.0",
  "description": "A cute AI pet for your Chrome browser with dynamic expressions and interactive features",
  "permissions": [
    "storage",
    "activeTab",
    "http://127.0.0.1:8888/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/assets/index-b265a61c.js"]
    }
  ]
}