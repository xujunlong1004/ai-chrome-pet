# Qwen API Key
Qwen_API_KEY=your_qwen_api_key
QWEN_CHAT_MODEL=qwen3-max
QWEN_MEMORY_JUDGE_MODEL=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v2
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Memory and knowledge base
MEMORY_IMPORTANCE_THRESHOLD=0.6
PUBLIC_KNOWLEDGE_ENABLED=true
# Optional. Defaults to ../public relative to backend.
# PUBLIC_KNOWLEDGE_DIR=/absolute/path/to/public

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=pet_ai_collection

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8888
